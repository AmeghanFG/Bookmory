@rendermode InteractiveServer
@using Bookmory.Data
@using Bookmory.Repositorios
@inject IRepositorioUsuarios repositorioUsuarios

<!-- Tarjeta ejemplo-->
<div class="card shadow-sm mis-libros-card"
     onmouseover="this.style.transform='translateY(-5px)';this.style.boxShadow='0 10px 28px rgba(0,0,0,.14)'"
     onmouseout="this.style.transform='';this.style.boxShadow=''">

    <div class="position-relative">
        <!-- Imagen portada -->
        <img src="@ImageUrl" class="card-img-top object-fit-cover book-height" alt="Portada">

        <!-- Estado: cambiar clase y texto según estado -->
        <span class="position-absolute top-0 end-0 mt-2 me-0 px-2 py-1 d-flex align-items-center gap-1 bg-light @statusStyle">     
            <span class="small">●</span> @Status
        </span>
    </div>

    <div class="card-body px-3 pt-2 pb-1">
        <p class="mb-0 fw-bold fs-5 text-dark lh-sm">@Title</p>
        <p class="mb-2 small text-secondary">@Author</p>
    </div>

    <div class="d-flex gap-2 px-3 pb-3">
        <select class="form-select" value="@Status" @onchange="CambioEstado" aria-label="Seleccionar estado">
            <option value="Sin empezar">Sin empezar</option>
            <option value="En proceso">En proceso</option>
            <option value="Terminado">Terminado</option>
        </select>
        <button class="btn btn-sm btn-outline-danger" @onclick="EliminarLibro">🗑️</button>
    </div>
</div>

@code {

    [Parameter]
    public string Title { get; set; }

    [Parameter]
    public int Id { get; set; }

    [Parameter]
    public string Author { get; set; }

    [Parameter]
    public string ImageUrl { get; set; }

    [Parameter]
    public string Status { get; set; }

    // volver a cargar la pag para mostrar la lista nueva después de eliminar
    [Parameter]
    public EventCallback OnEliminar { get; set; }

    string statusStyle = "";
    int _estadoId;

    // método -> el componente que se ejecuta automáticamente cuando el componente recibe parámetros de su componente padre y se asignan sus valores, es parecido a lo que se hacía en Razor
    protected override Task OnInitializedAsync()
    {
        statusStyleSelect();
        return base.OnInitializedAsync();
    }
    private async Task CambioEstado(ChangeEventArgs e)
    {
        Status = e.Value.ToString();
        statusStyleSelect();
        await actualizarEstado();
    }

    public void statusStyleSelect ()
    {
        if (Status == "En proceso"){
            statusStyle = "en-proceso";
            _estadoId = 2;
        } else if (Status == "Sin empezar"){
            statusStyle = "sin-empezar";
            _estadoId = 1;
        } else if (Status == "Terminado"){ 
            statusStyle = "terminado";
            _estadoId = 3;
        } else
        {
            statusStyle = "sin-empezar";
            _estadoId = 1;
        }
    }

    private async Task EliminarLibro()
    {
        await repositorioUsuarios.EliminarLibroPorUsuario(Id);
        await OnEliminar.InvokeAsync();
    }
    private async Task actualizarEstado()
    {
        await repositorioUsuarios.ActualizarEstado(Id, _estadoId);
    }
}
