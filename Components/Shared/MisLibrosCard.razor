@rendermode InteractiveServer
@using Bookmory.Repositorios
@inject IRepositorioMisLibros repositorioMisLibros

<!-- Tarjeta-->
<div class="card shadow-sm mis-libros-card justify-content-between"
     onmouseover="this.style.transform='translateY(-5px)';this.style.boxShadow='0 10px 28px rgba(0,0,0,.14)'"
     onmouseout="this.style.transform='';this.style.boxShadow=''">

    <div class="position-relative">
        <!-- Imagen portada -->
        <img src="@ImageUrl" class="card-img-top object-fit-cover book-height" alt="Portada">

        <!-- Estado: cambiar clase y texto según estado -->
        <span class="position-absolute top-0 end-0 mt-2 me-0 px-2 py-1 d-flex align-items-center gap-1 @statusStyle">     
            <span class="small">●</span> @Status
        </span>
    </div>

    <div class="card-body px-3 pt-2 pb-1">
        <p class="mb-0 fw-bold fs-5 text-dark lh-sm">@Title</p>
        <p class="mb-2 small text-secondary">@Author</p>
    </div>

    <div class="d-flex gap-2 px-3 pb-3">
        <select class="form-select" @bind="_estado" @bind:after="EstadoCambiado" aria-label="Seleccionar estado">
            <option value="no-empezado">No empezado</option>
            <option value="en-proceso">En proceso</option>
            <option value="terminado">Terminado</option>
        </select>
        <button class="btn btn-sm btn-outline-danger" @onclick="Eliminar">🗑️</button>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    [Parameter]
    public string Title { get; set; }

    [Parameter]
    public string Author { get; set; }

    [Parameter]
    public string ImageUrl { get; set; }

    [Parameter]
    public string Status { get; set; }

    // La IA me dio EvenCallback, investigando, notifica al componente padre, investigación: https://dev.to/stevsharp/mastering-blazor-component-communication-eventcallback-cascadingparameter-and-ref-explained-eig, recuerdo vagamente que algo así se podía en react, estudiar que era
    [Parameter]
    public EventCallback OnLibroEliminado { get; set; }

    string statusStyle = "";

    string _estado;

    // método -> el componente que se ejecuta automáticamente cuando el componente recibe parámetros de su componente padre y se asignan sus valores, es parecido a lo que se hacía en Razor
    protected override void OnParametersSet()
    {
        statusStyleSelect();
    }

    public void statusStyleSelect ()
    {
        if (Status == "En proceso") statusStyle = "en-proceso";
        if (Status == "No empezado") statusStyle = "no-empezado";
        if (Status == "Terminado") statusStyle = "terminado";
        if (string.IsNullOrEmpty(Status)) statusStyle = "no-empezado";
    }

    private async Task Eliminar()
    {
        await repositorioMisLibros.EliminarLibro(Id);
        await OnLibroEliminado.InvokeAsync(); // Aquí es donde notifica al componente padre cuando se ejecuta el método
    }

    // Método para convertir value de estado de nuevo por que se me ocurrio poner una clase css con esos nombres pero para la base de datos ocupo el normal como "No empezado"
    private string FormatearEstadoBD()
    {
        if (_estado == "no-empezado")
            return "No empezado";

        if (_estado == "en-proceso")
            return "En proceso";

        if (_estado == "terminado")
            return "Terminado";

        return "No empezado";
    }

    private async Task EstadoCambiado()
    {
        await repositorioMisLibros.CambiarEstado(Id, FormatearEstadoBD());

        Status = FormatearEstadoBD();

        statusStyleSelect(); // Para actualizar la tag de la clase de css
    }
}
